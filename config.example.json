{
  "port": 8080,
  "host": "0.0.0.0",

  "apiKeys": {
    "user1": "sk-user1-change-me",
    "user2": "sk-user2-change-me"
  },

  "accounts": [
    { "email": "account1@gmail.com", "refreshToken": "PASTE_REFRESH_TOKEN_HERE", "enabled": true },
    { "email": "account2@gmail.com", "refreshToken": "PASTE_REFRESH_TOKEN_HERE", "enabled": true }
  ],

  "userBindings": {
    "sk-user1-change-me": { "primary": "account1@gmail.com", "backup": "account2@gmail.com" },
    "sk-user2-change-me": { "primary": "account2@gmail.com", "backup": "account1@gmail.com" }
  },

  "pacer": {
    "maxRequestsPerMinute": 5,
    "burstSize": 3,
    "jitterMinMs": 1000,
    "jitterMaxMs": 4000,
    "dailyLimitPerAccount": 500
  },

  "session": {
    "minLifetimeMs": 7200000,
    "maxLifetimeMs": 21600000,
    "restartDelayMs": 10000
  },

  "retry": {
    "maxRetries": 2,
    "waitBeforeSwitch": 60000,
    "maxWaitMs": 120000
  },

  "heartbeat": {
    "enabled": true,
    "intervalMs": 1800000
  },

  "versionPools": {
    "antigravity": ["1.108.0", "1.108.1", "1.109.0", "1.109.1", "1.110.0"],
    "vscode": ["1.96.0", "1.96.1", "1.96.2", "1.97.0", "1.97.1", "1.98.0"],
    "node": ["20.12.0", "20.12.2", "20.13.1", "20.14.0", "22.11.0", "22.12.0"]
  },

  "outboundProxy": null
}
